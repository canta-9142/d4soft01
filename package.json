{
    "scripts": {
        "dev:css": "tailwindcss -i ./src/tailwind.css -o ./dist/tailwind.css --watch",
        "build:css": "tailwindcss -i ./src/tailwind.css -o ./dist/tailwind.css --minify",
        "dev:ts": "tsc --watch",
        "build:ts": "tsc",
        "dev": "concurrently \"npm run dev:css\" \"npm run dev:ts\"",
        "build": "npm run build:css && npm run build:ts"
    },
    "devDependencies": {
        "@tailwindcss/cli": "^4.3.2",
        "tailwindcss": "^4.3.2",
        "typescript": "^6.0.3"
    }
}
